---
import BaseLayout from '../layouts/BaseLayout.astro';
import InstallCommand from '../components/InstallCommand.astro';
---

<BaseLayout title="Page not found — nukenpm" path="/404">
	<div
		style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 32px;text-align:center;background:radial-gradient(1100px 620px at 50% -8%,#16191f,#0d0e11 62%)"
	>
		<p
			style="font-family:'JetBrains Mono',monospace;font-size:12px;color:#5fd0c5;letter-spacing:1px;margin:0 0 16px"
		>
			404
		</p>
		<h1
			style="font-family:'JetBrains Mono',monospace;font-weight:700;font-size:36px;line-height:1.15;margin:0 0 14px;color:#f2f4f7"
		>
			Page not found.
		</h1>
		<p style="font-size:16px;line-height:1.6;color:#8b909a;max-width:420px;margin:0 0 32px">
			This path doesn't exist. Head back to the landing page or install nukenpm below.
		</p>
		<a
			href="/"
			style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d0e11;background:#5fd0c5;text-decoration:none;padding:10px 18px;border-radius:8px;font-weight:600;margin-bottom:28px"
			>← Back home</a
		>
		<InstallCommand variant="cta" />
		<div id="copy-status" class="sr-only" aria-live="polite" aria-atomic="true"></div>
	</div>
</BaseLayout>

<style is:global>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>

<script>
	import { wireCopyButtons } from '../scripts/copy';
	wireCopyButtons(document.getElementById('copy-status'));
</script>
